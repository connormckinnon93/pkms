# Obsidian per-vault state that is machine-specific / high-churn
# (the rest of .obsidian/ — settings, hotkeys — is tracked)
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json
**/.obsidian/cache
**/.obsidian/.trash/
# View Count plugin's per-open cache (canonical counts are synced to note frontmatter)
**/.obsidian/view-count.json

# Vendored community plugin code (installed via Obsidian, not source-controlled here)
**/.obsidian/plugins/

# macOS
.DS_Store
