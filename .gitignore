**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json
**/.obsidian/cache
**/.obsidian/.trash/

# Vendored community plugin code (installed via Obsidian, not source-controlled here)
**/.obsidian/plugins/

# macOS
.DS_Store
